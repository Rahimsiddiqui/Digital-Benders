  }
  .company-info {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-right: -10px;
    gap: 35px;
  }
  .company-info label {
    font-size: 14px;
    font-weight: bold;
  }
  .company-info img {
    max-width: 40px;
    max-height: 40px;
    margin-right: 15px;
  }
  .footer-row svg {
    background-color: white;
    fill: black;
    transition: all 0.3s ease-in-out;
    border-radius: 50%;
    padding: 9px;
  }
  .payment-methods {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-right: 5%;
  }
  .payment-methods p {
    font-weight: 400;
  }
  .payment-methods img {
    max-width: 40px;
    max-height: 40px;
    margin-right: 7px;
  }
  .footer-row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 0 0 0 5%;
    margin-top: 20px;
  }
  .media-links {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-top: -17px;
    gap: 20px;
    transition: all 0.3s ease-in-out;
  }
  @keyframes hovered {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-2px);
    }
  }
  @keyframes active {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(1px);
    }
  }
  .media-links a:hover {
    animation: hovered 0.3s forwards;
  }
  .media-links a:active {
    animation: active 0.3s forwards;
  }
</style>

