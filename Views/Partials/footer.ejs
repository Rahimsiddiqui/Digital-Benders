<script>
  const footerRow = document.querySelector(`.footer-row`);
  const svgs = footerRow.querySelectorAll(`svg`);
  const inputGroupText = document.querySelector(`.input-group-text`);
  const svg = inputGroupText.querySelector(`svg`);

  svgs.forEach((icon, i) => {
    icon.addEventListener(`mouseover`, () => {
      icon.style.backgroundColor = "rgb(203, 18, 18)";
      icon.style.fill = "white";
      icon.classList.remove(`active`);
      icon.classList.add(`hovered`);
    });
    icon.addEventListener(`mouseleave`, () => {
      icon.style.backgroundColor = "white";
      icon.style.fill = "black";
      icon.classList.remove(`hovered`);
      icon.classList.add(`active`);
    });
  });

  const teleRed = () => {
    svg.style.fill = "rgb(203, 18, 18)";
  };

  const teleNormal = () => {
    svg.style.fill = "black";
  };

  svg.addEventListener(`mouseover`, teleRed);

  svg.addEventListener(`mouseleave`, teleNormal);

  const handleSubscribe = () => {
    const spinner = document.querySelector(`.newsletter-spinner`);
    const subscribeInput = document.querySelector(`#subscribe`);

    spinner.style.display = "inline-block";

    setTimeout(() => {
      if (subscribeInput.value.trim() === "") {
        Swal.fire({
          title: "Oops...",
          text: "You didn't enter a valid email address.",
          timer: 3000,
          icon: "error",
        });
        spinner.style.display = "none";

        return;
      } else {
        Swal.fire({
          title: "Thank You!",
          text: `"${subscribeInput.value}" Newsletter subscribed successfully!`,
          timer: 3000,
          icon: "success",
        });
      }
      spinner.style.display = "none";
      subscribeInput.value = "";
      form.reset();
    }, 3000);
  };
</script>
